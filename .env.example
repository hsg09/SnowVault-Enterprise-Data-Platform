# =============================================================================
# Environment Variables — Data Vault 2.0 Snowflake Data Platform
#
# USAGE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your credentials (NEVER commit .env)
#   3. dbt reads these via {{ env_var('...') }} in profiles.yml
#   4. Airflow reads these via BashOperator env injection
# =============================================================================

# ---------------------------------------------------------------------------
# Snowflake Connection (Primary Region — AWS US East 1)
# ---------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=your_username

# RSA Key-pair authentication (REQUIRED — password auth is prohibited)
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_passphrase

SNOWFLAKE_ROLE=DATA_ENGINEER
SNOWFLAKE_WAREHOUSE=TRANSFORMER_WH
SNOWFLAKE_DATABASE=RAW_VAULT

# ---------------------------------------------------------------------------
# Snowflake Multi-Region (Secondary Accounts)
# ---------------------------------------------------------------------------
# SNOWFLAKE_ACCOUNT_AWS_EU=your_account.eu-west-1
# SNOWFLAKE_ACCOUNT_AZURE_EAST=your_account.east-us-2.azure
# SNOWFLAKE_ACCOUNT_AZURE_WEST=your_account.west-europe.azure
# SNOWFLAKE_ACCOUNT_GCP_US=your_account.us-central1.gcp
# SNOWFLAKE_ACCOUNT_GCP_EU=your_account.europe-west1.gcp

# ---------------------------------------------------------------------------
# dbt Configuration
# ---------------------------------------------------------------------------
DBT_DEV_USER=local
DBT_TARGET=dev
DBT_THREADS=4

# ---------------------------------------------------------------------------
# AWS (S3 stages, IAM)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_DEFAULT_REGION=us-east-1
S3_RAW_BUCKET=your-company-data-lake-raw

# ---------------------------------------------------------------------------
# Azure (ADLS Gen2 stages)
# ---------------------------------------------------------------------------
# AZURE_STORAGE_ACCOUNT=yourstorageaccount
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ---------------------------------------------------------------------------
# GCP (GCS stages)
# ---------------------------------------------------------------------------
# GCP_PROJECT_ID=your-gcp-project
# GCS_RAW_BUCKET=your-gcs-data-lake-raw

# ---------------------------------------------------------------------------
# Kafka / CDC (Confluent / MSK)
# ---------------------------------------------------------------------------
# KAFKA_BOOTSTRAP_SERVERS=your-kafka-cluster:9092
# KAFKA_SCHEMA_REGISTRY_URL=https://your-schema-registry:8081
# KAFKA_API_KEY=your_kafka_key
# KAFKA_API_SECRET=your_kafka_secret

# ---------------------------------------------------------------------------
# Observability (Monte Carlo / Metaplane)
# ---------------------------------------------------------------------------
MONTE_CARLO_API_KEY=your_monte_carlo_api_key
MONTE_CARLO_API_SECRET=your_monte_carlo_api_secret
# METAPLANE_API_KEY=your_metaplane_api_key

# ---------------------------------------------------------------------------
# Alerting & Notifications
# ---------------------------------------------------------------------------
# DATADOG_API_KEY=your_datadog_key
# DATADOG_APP_KEY=your_datadog_app_key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------
# TF_VAR_snowflake_account=your_account
# TF_VAR_snowflake_user=your_tf_user
# TF_VAR_snowflake_private_key_path=/path/to/terraform_rsa_key.p8
